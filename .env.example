# Application
APP_NAME=LearnCRM Sync API
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql://learncrm:learncrm_secret@localhost:5432/learncrm_db

# SQLite alternative (for local dev)
# DATABASE_URL=sqlite:///./learncrm.db

# JWT Authentication
SECRET_KEY=replace-with-a-secure-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API Key (for service-to-service auth)
API_KEY=replace-with-a-secure-api-key

# Rate Limiting
RATE_LIMIT=100/minute

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=INFO
